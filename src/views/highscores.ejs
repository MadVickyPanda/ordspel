<!DOCTYPE html>
<html lang="sv">

<head>
  <meta charset="UTF-8">
  <link rel="stylesheet" href="/style.css">
  <title>Highscores</title>

  <style>
    body {
      margin: 0;
      background: #121213;
      color: white;
      font-family: Arial, sans-serif;
      display: flex;
      justify-content: center;
      padding-top: 50px;
    }

    .container {
      width: 700px;
      text-align: center;
    }

    /*NAVBAR*/
    .nav {
      display: flex;
      justify-content: center;
      gap: 10px;
      margin-bottom: 20px;
    }

    .nav a {
      background: transparent;
      border: none;
      color: #aaa;
      font-size: 14px;
      cursor: pointer;
      padding: 6px 10px;
      text-decoration: none;
      transition: 0.2s;
    }

    .nav a:hover {
      color: white;
    }

    .nav a.active {
      color: white;
      border-bottom: 2px solid white;
    }

    h1 {
      margin-bottom: 5px;
    }

    .subtitle {
      color: #888;
      margin-bottom: 20px;
      font-size: 14px;
    }

    table {
      width: 100%;
      border-collapse: collapse;
      background: #1a1a1b;
      border-radius: 10px;
      overflow: hidden;
    }

    th {
      background: #2a2a2b;
      padding: 12px;
      font-size: 12px;
      text-transform: uppercase;
      letter-spacing: 1px;
      color: #bbb;
    }

    td {
      padding: 12px;
      border-bottom: 1px solid #2f2f2f;
    }

    tr:hover {
      background: #2a2a2b;
    }

    .rank {
      font-weight: bold;
      width: 60px;
    }

    .gold {
      color: #ffd700;
    }

    .silver {
      color: #c0c0c0;
    }

    .bronze {
      color: #cd7f32;
    }

    .badge {
      font-size: 18px;
    }
  </style>
</head>

<body>
  <div class="container">

    <!-- NAVBAR -->
    <div class="nav">
      <a href="/" class="<%= activePage === 'game' ? 'active' : '' %>">Spel</a>
      <a href="/about" class="<%= activePage === 'about' ? 'active' : '' %>">Om</a>
      <a href="/highscores" class="<%= activePage === 'highscores' ? 'active' : '' %>">Highscores</a>
    </div>

    <h1>🏆 Highscores</h1>
    <div class="subtitle">Bästa Wordle-spelarna</div>

    <table>
      <tr>
        <th>#</th>
        <th>Namn</th>
        <th>Tid</th>
        <th>Gissningar</th>
        <th>Svårighet</th>
      </tr>

      <% scores.forEach((s, i)=> {
        let medal = '';
        let emoji = '';

        if (i === 0) {
        medal = 'gold';
        emoji = '🥇';
        } else if (i === 1) {
        medal = 'silver';
        emoji = '🥈';
        } else if (i === 2) {
        medal = 'bronze';
        emoji = '🥉';
        }
        %>

        <tr>
          <td class="rank <%= medal %>">
            <span class="badge">
              <%= emoji %>
            </span>
            <%= i + 1 %>
          </td>

          <td>
            <%= s.name %>
          </td>
          <td>
            <td><%= (s.time / 1000).toFixed(1) %>s</td>
          </td>
          <td>
            <%= s.guesses %>
          </td>
          <td>
            <%= s.length %> bokstäver
          </td>
        </tr>

        <% }) %>

    </table>

  </div>
</body>

</html>